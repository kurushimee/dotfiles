{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "name": "LiteLLM",
        "baseURL": "{PASTE_LITELLM_URL_HERE}",
        "litellmProxy": true
      },
      "models": {
        "mini-max/m3": {
          "name": "MiniMax M3",
          "limit": {
            "context": 512000,
            "output": 128000
          },
          "tool_call": true,
          "modalities": {
            "input": [
              "image",
              "text"
            ]
          },
          "attachment": true,
          "temperature": true,
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_details"
          },
          "options": {
            "thinking": {
              "type": "adaptive"
            },
            "reasoning_split": true
          },
          "variants": {
            "adaptive": {
              "thinking": {
                "type": "adaptive"
              },
              "reasoning_split": true
            },
            "fast": {
              "thinking": {
                "type": "disabled"
              },
              "reasoning_split": true
            }
          }
        },
        "claude-max/opus": {
          "name": "Claude Opus",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "reasoning": true,
          "tool_call": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ]
          },
          "options": {
            "reasoningEffort": "high",
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "thinking": {
                "type": "adaptive",
                "display": "summarized"
              }
            },
            "medium": {
              "reasoningEffort": "medium",
              "thinking": {
                "type": "adaptive",
                "display": "summarized"
              }
            },
            "high": {
              "reasoningEffort": "high",
              "thinking": {
                "type": "adaptive",
                "display": "summarized"
              }
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "thinking": {
                "type": "adaptive",
                "display": "summarized"
              }
            },
            "max": {
              "reasoningEffort": "max",
              "thinking": {
                "type": "adaptive",
                "display": "summarized"
              }
            }
          }
        },
        "claude-max/sonnet": {
          "name": "Claude Sonnet",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ]
          },
          "options": {
            "reasoningEffort": "high",
            "thinking": {
              "type": "adaptive"
            }
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "thinking": {
                "type": "adaptive"
              }
            },
            "medium": {
              "reasoningEffort": "medium",
              "thinking": {
                "type": "adaptive"
              }
            },
            "high": {
              "reasoningEffort": "high",
              "thinking": {
                "type": "adaptive"
              }
            },
            "max": {
              "reasoningEffort": "max",
              "thinking": {
                "type": "adaptive"
              }
            }
          }
        },
        "claude-max/haiku": {
          "name": "Claude Haiku",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budget_tokens": 8192
            }
          },
          "variants": {
            "low": {
              "thinking": {
                "type": "enabled",
                "budget_tokens": 4096
              }
            },
            "medium": {
              "thinking": {
                "type": "enabled",
                "budget_tokens": 8192
              }
            },
            "high": {
              "thinking": {
                "type": "enabled",
                "budget_tokens": 16000
              }
            },
            "xhigh": {
              "thinking": {
                "type": "enabled",
                "budget_tokens": 32000
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budget_tokens": 63999
              }
            }
          }
        }
      }
    }
  },
  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{PASTE_CTX7_API_KEY_HERE}"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}